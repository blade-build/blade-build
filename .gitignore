.idea
*.swp
*.pyc
.DS_Store

blade-bin
.Building.lock
# Build output dirs: build_<profile> (v3 default), plus the pre-v3 build${bits}_*
# legacy names kept for projects still on the old default.
build_*
build32_*
build64_*
# ...but not the docs dir that happens to start with "build_".
!**/build_rules/

/blade.zip

/.coverage*
__pycache__

# Local AI-agent working area. See .agent/README.md for the layout.
# Default: everything under .agent/ is local-only. Tracked paths are
# explicitly un-ignored below (order matters — blanket ignore first,
# then reopens).
/.agent/*
!/.agent/README.md
!/.agent/tools/
/.agent/tools/*
!/.agent/tools/*.py
!/.agent/tools/*.sh
!/.agent/tools/README.md
.claude/

# MkDocs build output (docs are deployed to blade-build.github.io)
/_site/
